# Copy to .env and fill in. .env is git-ignored — never commit real values.
# Used by the acceptance tests (make testacc) and local smoke testing.

# Base address of the AAP platform (no trailing path).
export TEST_AAP_ADDRESS="https://aap-aap.apps.openshift-01.hashicorp.local"

# A privileged AAP OAuth2 token the engine uses to mint/revoke other tokens.
export TEST_AAP_TOKEN="replace-me-do-not-commit"

# API base path that exposes the token endpoints.
#   AAP 2.5+ (platform gateway):  /api/gateway/v1
#   AAP 2.4  (controller direct): /api/controller/v2
export TEST_AAP_TOKENS_API_PATH="/api/gateway/v1"

# Lab clusters often use a private/self-signed CA. Set to true to skip TLS verify
# for local testing only. In production, configure ca_cert instead.
export TEST_AAP_SKIP_TLS_VERIFY="true"
